    {
      "parameters": {
        "jsCode": "return $input.all().map((item, i) => {\n  let parsed;\n  try {\n    parsed = JSON.parse(item.json.choices[0].message.content);\n  } catch (e) {\n    parsed = { extraction_error: `Failed to parse Groq output: ${e.message}`, confidence_score: 0 };\n  }\n\n  const emailMeta = $('Get many messages').all()[i]?.json;\n\n  return {\n    json: {\n      ...parsed,\n      sender_email: emailMeta?.from?.value?.[0]?.address ?? null,\n      email_subject: emailMeta?.subject ?? null,\n      received_at: emailMeta?.date ?? null\n    }\n  };\n});"
      },
