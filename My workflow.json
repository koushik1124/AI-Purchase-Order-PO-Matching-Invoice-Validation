    {
      "parameters": {
        "jsCode": "return $('Code in JavaScript').all().map((invItem, i) => {\n  const invoice = invItem.json;\n\n  // If extraction itself failed upstream, short-circuit — don't run comparison on garbage\n  if (invoice.extraction_error) {\n    return {\n      json: {\n        ...invoice,\n        discrepancy_summary: \"Extraction failed — manual review required\",\n        validation_status: \"Procurement Review\"\n      }\n    };\n  }\n\n  const poResults = $('Search records').all();\n  const po = poResults.find(p => p.json[\"PO Number\"] === invoice.po_number)?.json;\n\n  if (!po) {\n    return {\n      json: {\n        ...invoice,\n        discrepancy_summary: \"Missing Purchase Order\",\n        validation_status: \"Rejected\"\n      }\n    };\n  }\n\n  const discrepancies = [];\n  if (invoice.vendor_name !== po.Vendor) discrepancies.push(\"Vendor mismatch\");\n  if (invoice.po_number !== po[\"PO Number\"]) discrepancies.push(\"PO number mismatch\");\n  if (invoice.currency !== po.Currency) discrepancies.push(\"Currency mismatch\");\n\n  let poItems;\n  try {\n    poItems = JSON.parse(po[\"Approved Line Items\"]);\n  } catch (e) {\n    discrepancies.push(\"PO line items unreadable — manual review required\");\n    poItems = [];\n  }\n\n  if (Array.isArray(invoice.line_items)) {\n    invoice.line_items.forEach(li => {\n      const match = poItems.find(p => p.item === li.item);\n      if (!match) {\n        discrepancies.push(`Additional line item: ${li.item}`);\n      } else {\n        if (li.quantity !== match.quantity) discrepancies.push(`Quantity mismatch: ${li.item}`);\n        if (li.unit_price !== match.unit_price) discrepancies.push(`Unit price mismatch: ${li.item}`);\n      }\n    });\n  } else {\n    discrepancies.push(\"Invoice line items missing or malformed\");\n  }\n\n  poItems.forEach(p => {\n    if (!invoice.line_items?.find(i => i.item === p.item)) discrepancies.push(`Missing line item: ${p.item}`);\n  });\n\n  if (typeof invoice.net_amount === 'number' && invoice.net_amount > po[\"Total Amount\"]) {\n    discrepancies.push(\"Invoice total exceeds PO value\");\n  }\n\n  const validation_status = discrepancies.length === 0 ? \"Ready for Payment\"\n    : discrepancies.length <= 2 ? \"Procurement Review\"\n    : \"Rejected\";\n\n  return {\n    json: {\n      ...invoice,\n      discrepancy_summary: discrepancies.join(\"; \") || \"None\",\n      validation_status\n    }\n  };\n});"
      },
