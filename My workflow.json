        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model:  \"openai/gpt-oss-120b\",\n  messages: [{\n    role: \"user\",\n    content: \"Extract invoice data from the following text and return ONLY valid JSON with keys: vendor_name, vendor_id, po_number, invoice_number, invoice_date, due_date, currency, net_amount, tax_amount, gross_amount, line_items (array of {item, quantity, unit_price, line_total}), confidence_score (0-1), extraction_warnings (array). No markdown, JSON only.\\n\\nInvoice text:\\n\" + $json.text\n  }],\n  response_format: {type: \"json_object\"}\n}) }}",
